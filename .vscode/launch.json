{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug NestJS Backend",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/node_modules/@nestjs/cli/bin/nest.js",
            "args": [
                "start",
                "--debug",
                "--watch"
            ],
            "cwd": "${workspaceFolder}/apps/backend",
            "env": {
                "NODE_ENV": "development"
            },
            "console": "integratedTerminal",
            "sourceMaps": true,
            "restart": true,
            "runtimeExecutable": "node",
            "runtimeArgs": ["--inspect-brk=9229"]
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug NestJS (Direct)",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/apps/backend/src/main.ts",
            "cwd": "${workspaceFolder}/apps/backend",
            "runtimeArgs": [
                "--require",
                "ts-node/register",
                "--inspect-brk=9229"
            ],
            "env": {
                "NODE_ENV": "development"
            },
            "console": "integratedTerminal",
            "sourceMaps": true,
            "outFiles": [
                "${workspaceFolder}/apps/backend/dist/**/*.js"
            ]
        },
        {
            "type": "node",
            "request": "attach",
            "name": "Attach to NestJS",
            "port": 9229,
            "restart": true,
            "localRoot": "${workspaceFolder}/apps/backend",
            "remoteRoot": "${workspaceFolder}/apps/backend",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "sourceMaps": true
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Tests",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/node_modules/.bin/jest",
            "args": [
                "--runInBand",
                "--no-cache",
                "--config",
                "${workspaceFolder}/apps/backend/jest.config.js"
            ],
            "cwd": "${workspaceFolder}/apps/backend",
            "console": "integratedTerminal",
            "env": {
                "NODE_ENV": "test"
            },
            "sourceMaps": true
        }
    ]
}