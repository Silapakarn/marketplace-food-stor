generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id              Int         @id @default(autoincrement())
  name            String      @db.VarChar(100)
  color           String      @unique @db.VarChar(50)
  price           Decimal     @db.Decimal(10, 2)
  imageUrl        String?     @map("image_url") @db.VarChar(255)
  currencyId      Int         @map("currency_id")
  hasPairDiscount Boolean     @default(false) @map("has_pair_discount")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @default(now()) @updatedAt @map("updated_at")
  currency        Currency    @relation(fields: [currencyId], references: [id])
  orderItems      OrderItem[]

  @@map("products")
}

model Order {
  id                   Int            @id @default(autoincrement())
  memberCardNumber     String?        @map("member_card_number") @db.VarChar(50)
  totalBeforeDiscount  Decimal        @map("total_before_discount") @db.Decimal(10, 2)
  pairDiscount         Decimal        @default(0) @map("pair_discount") @db.Decimal(10, 2)
  memberDiscount       Decimal        @default(0) @map("member_discount") @db.Decimal(10, 2)
  finalTotal           Decimal        @map("final_total") @db.Decimal(10, 2)
  createdAt            DateTime       @default(now()) @map("created_at")
  orderItems           OrderItem[]
  redSetOrders         RedSetOrder[]

  @@map("orders")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int     @map("order_id")
  productId Int     @map("product_id")
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)
  subtotal  Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model RedSetOrder {
  id        Int      @id @default(autoincrement())
  orderId   Int      @map("order_id")
  orderedAt DateTime @default(now()) @map("ordered_at")
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("red_set_orders")
}

model Currency {
  id           Int       @id @default(autoincrement())
  code         String    @unique @db.VarChar(3) // THB, USD, etc.
  name         String    @db.VarChar(50) // Thai Baht, US Dollar, etc.
  symbol       String    @db.VarChar(10) // ฿, $, etc.
  exchangeRate Decimal   @db.Decimal(10, 4) // Exchange rate to base currency
  isActive     Boolean   @default(true) @map("is_active")
  isDefault    Boolean   @default(false) @map("is_default")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")
  products     Product[] // One-to-many relationship

  @@map("currencies")
}

model InventoryLock {
  id                 Int      @id @default(autoincrement())
  lockKey            String   @unique @map("lock_key") @db.VarChar(100)
  productId          Int      @map("product_id")
  customerIdentifier String   @map("customer_identifier") @db.VarChar(255)
  acquiredAt         DateTime @default(now()) @map("acquired_at")
  expiresAt          DateTime @map("expires_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([productId])
  @@index([expiresAt])
  @@map("inventory_locks")
}
